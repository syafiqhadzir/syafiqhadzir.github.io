{#
    Navigation Data Partial
    Used to render consistent navigation across all pages

    @module _includes/partials/nav.njk
#}
<nav class="navbar" aria-label="Main Navigation">
    <a href="/" id="author-name" {{ 'class=active' if page.url === '/' }} aria-label="Home page">
        {{ site.title }}
    </a>

    <ul class="navbar-ul">
        <li>
            <a href="/contact.html" class="nav-link {{ 'active' if page.url === '/contact.html' or page.url === '/contact/' }}" aria-label="Contact page">
                Contact
            </a>
        </li>
        <li>
            <a href="/sitemap.html" class="nav-link {{ 'active' if page.url === '/sitemap.html' or page.url === '/sitemap/' }}" aria-label="Sitemap page">
                Sitemap
            </a>
        </li>
        <li>
            <button class="theme-toggle"
                on="tap:AMP.setState({theme: {mode: theme.mode == 'dark' ? 'light' : 'dark'}})"
                aria-label="Toggle dark mode">
                <i class="fas fa-moon moon-icon" aria-hidden="true"></i>
                <i class="fas fa-sun sun-icon" aria-hidden="true"></i>
            </button>
        </li>
    </ul>
</nav>
