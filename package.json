{
    "name": "syafiqhadzir.github.io",
    "version": "2.0.0",
    "description": "Google AMP Portfolio with Eleventy - Software QA Engineer",
    "keywords": [
        "eleventy",
        "amp",
        "portfolio",
        "typescript",
        "docker"
    ],
    "homepage": "https://syafiqhadzir.dev",
    "bugs": {
        "url": "https://github.com/syafiqhadzir/syafiqhadzir.github.io/issues",
        "email": "syafiqhadzir@live.com.my"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/syafiqhadzir/syafiqhadzir.github.io.git"
    },
    "license": "CC0-1.0",
    "author": {
        "name": "Syafiq Hadzir",
        "email": "syafiqhadzir@live.com.my",
        "url": "https://syafiqhadzir.dev"
    },
    "type": "module",
    "scripts": {
        "prebuild": "npm run compile:ts",
        "build": "eleventy",
        "build:prod": "npx tsx scripts/build-production.ts",
        "build:size-report": "npx tsx scripts/build-size-report.ts _site",
        "build:sw": "workbox generateSW workbox-config.cjs",
        "check": "npm run lint && npm run typecheck && npm run test:unit",
        "check:html": "npx tsx scripts/html-validate.ts _site",
        "check:links": "npx tsx scripts/link-checker.ts _site",
        "clean": "node scripts/clean.js _site coverage cypress/reports dist",
        "compile:ts": "tsc -p tsconfig.json",
        "predev": "npm run compile:ts",
        "dev": "eleventy --serve",
        "docker:build": "docker build -t syafiqhadzir-portfolio .",
        "docker:run": "docker run -p 8080:80 syafiqhadzir-portfolio",
        "docker:test": "docker build -t syafiqhadzir-portfolio . && docker run --rm -d -p 8080:80 --name portfolio-test syafiqhadzir-portfolio && curl -f http://localhost:8080/health && docker stop portfolio-test",
        "housekeeping": "npx tsx scripts/housekeeping.ts",
        "housekeeping:knip": "npx knip",
        "housekeeping:knip:fix": "npx knip --fix",
        "lint": "npm run lint:js && npm run lint:css",
        "lint:css": "stylelint src/**/*.scss --fix",
        "lint:css:report": "stylelint src/**/*.scss --formatter json --output-file stylelint-report.json",
        "lint:deps": "depcruise src scripts --config .dependency-cruiser.cjs",
        "lint:js": "eslint src/**/*.ts test/**/*.ts scripts/**/*.ts --fix",
        "lint:js:report": "eslint src/**/*.ts test/**/*.ts scripts/**/*.ts -f json -o eslint-report.json",
        "perf": "echo 'Use treosh/lighthouse-ci-action in GitHub Actions'",
        "perf:ci": "lhci autorun",
        "prepare": "husky",
        "serve": "npx serve _site -l 8080",
        "serve:static": "npx serve . -l 8080",
        "sonar": "npm run sonar:prepare && sonar-scanner",
        "sonar:prepare": "npm run test:unit:coverage && npm run lint:js:report && npm run lint:css:report",
        "test": "npm run test:unit && npm run test:e2e",
        "test:a11y": "cypress run --spec 'cypress/e2e/a11y.cy.ts'",
        "test:clean": "node scripts/clean.js cypress/reports cypress/screenshots coverage",
        "test:e2e": "cypress run",
        "test:e2e:ci": "cypress run --browser chrome",
        "test:e2e:open": "cypress open",
        "test:perf": "cypress run --spec 'cypress/e2e/performance.cy.ts'",
        "test:security": "cypress run --spec 'cypress/e2e/security-headers.cy.ts'",
        "test:seo": "cypress run --spec 'cypress/e2e/seo.cy.ts'",
        "test:smoke": "cypress run --spec 'cypress/e2e/smoke.cy.ts'",
        "test:unit": "vitest run",
        "test:unit:coverage": "vitest run --coverage",
        "test:unit:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "validate": "npm run validate:amp && npm run validate:schema && npm run check:html && npm run check:links",
        "validate:amp": "npx tsx scripts/validate-amp.ts",
        "validate:amp:build": "npx tsx scripts/validate-amp.ts _site",
        "validate:schema": "npx tsx scripts/validate-schema.ts _site"
    },
    "overrides": {
        "glob": "^10.4.5",
        "node-forge": "^1.3.3",
        "qs": "^6.14.1",
        "tmp": "^0.2.3"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.1.5",
        "@11ty/eleventy-img": "^6.0.4",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@lhci/cli": "^0.15.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/html-minifier-terser": "^7.0.2",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.2",
        "amphtml-validator": "^1.0.38",
        "autoprefixer": "^10.4.27",
        "axe-core": "^4.11.2",
        "cypress": "^15.13.0",
        "cypress-axe": "^1.7.0",
        "cypress-mochawesome-reporter": "^4.0.2",
        "dependency-cruiser": "^17.3.10",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "html-minifier-terser": "^7.2.0",
        "husky": "^9.1.7",
        "knip": "^6.2.0",
        "lightningcss": "^1.32.0",
        "lint-staged": "^16.4.0",
        "postcss": "^8.5.8",
        "postcss-discard-duplicates": "^7.0.2",
        "postcss-sort-media-queries": "^6.3.3",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "semantic-release": "^25.0.3",
        "sonarqube-scanner": "^4.3.5",
        "sort-package-json": "^3.6.1",
        "stylelint": "^17.6.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.2",
        "vitest-sonar-reporter": "^3.0.0",
        "workbox-cli": "^7.4.0"
    },
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    }
}
