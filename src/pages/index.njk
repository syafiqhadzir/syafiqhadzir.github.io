---
layout: base.njk
title: Syafiq Hadzir
description: Portfolio of Syafiq Hadzir - AI-assisted Software QA Engineer specializing in test automation and quality assurance.
contentLabel: Portfolio content
permalink: /
---

{% block structuredData %}
<script type="application/ld+json">
[
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "{{ site.author }}",
        "jobTitle": "{{ site.jobTitle }}",
        "description": "{{ site.description }}",
        "url": "{{ site.url }}",
        "email": "{{ site.email }}",
        "sameAs": [
            "{{ site.social.github }}",
            "{{ site.social.gitlab }}",
            "{{ site.social.blog }}"
        ],
        "worksFor": {
            "@type": "Organization",
            "name": "{{ site.company.name }}",
            "url": "{{ site.company.url }}"
        }
    }
]
</script>
{% endblock %}

<section class="profile-section">
    <div class="profile-picture">
        {% ampImg {
            src: "/images/headshot.webp",
            alt: site.author,
            width: 120,
            height: 120,
            layout: "responsive",
            "data-hero": true
        } %}
    </div>
    <div class="hero-content">
        <h1 class="gradient-text">{{ site.author }}</h1>
        <p class="lead">{{ site.jobTitle }} @ <a href="{{ site.company.url }}" target="_blank" rel="noopener">{{ site.company.name }}</a></p>
        <div class="status-badge">
            <span class="badge"><i class="fas fa-check-circle"></i> Available for collaboration</span>
        </div>
    </div>
</section>

<div class="prose">
    <p>Hi! I am <strong>{{ site.author }}</strong>, an <abbr title="Artificial Intelligence">AI</abbr>-assisted Software <abbr title="Quality Assurance">QA</abbr> Engineer. I actively leverage cutting-edge <abbr title="Artificial Intelligence">AI</abbr> tools and methodologies to enhance the efficiency and effectiveness of the software testing lifecycle.</p>
</div>

<hr class="section-divider">

<div class="grid md:grid-cols-2 gap-6">
    <section class="card">
        <h3><i class="fa-solid fa-flask fa-fw"></i> Research</h3>
        <p>Exploring the intersections of AI and software quality assurance, specifically machine learning for defect prediction and test optimization.</p>
        <a href="https://research.syafiqhadzir.dev">View Research Portfolio &rarr;</a>
    </section>

    <section class="card">
        <h3><i class="fa-solid fa-code fa-fw"></i> Projects</h3>
        <p>Open-source contributions and personal projects focusing on developer tooling, automation, and performance.</p>
        <a href="{{ site.social.github }}">Explore on GitHub &rarr;</a>
    </section>
</div>

<section class="mt-12">
    <h2>Proficiencies</h2>
    <div class="flex flex-wrap mt-4">
        <span class="badge">TypeScript</span>
        <span class="badge">Node.js</span>
        <span class="badge">Eleventy</span>
        <span class="badge">AMP</span>
        <span class="badge">Cypress</span>
        <span class="badge">Test Automation</span>
        <span class="badge">CI/CD</span>
        <span class="badge">Sass</span>
    </div>
</section>

<section class="mt-12">
    <h2>Interests</h2>
    <ul class="grid grid-cols-2 md:grid-cols-3 gap-2 list-none p-0">
        <li><i class="fa-solid fa-brain fa-fw text-accent mr-2"></i> AI Exploration</li>
        <li><i class="fa-solid fa-infinity fa-fw text-accent mr-2"></i> CI/CD</li>
        <li><i class="fa-solid fa-code fa-fw text-accent mr-2"></i> Code Assessment</li>
        <li><i class="fa-solid fa-window-maximize fa-fw text-accent mr-2"></i> Web Apps</li>
        <li><i class="fa-solid fa-signature fa-fw text-accent mr-2"></i> Tech Writing</li>
    </ul>
</section>
