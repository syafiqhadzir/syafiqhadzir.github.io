---
layout: base.njk
title: Contact
description: Get in touch with Syafiq Hadzir, Software QA Engineer.
contentLabel: Contact information
permalink: /contact.html
---

{% block structuredData %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact - Syafiq Hadzir",
    "description": "Get in touch with Syafiq Hadzir, Software QA Engineer.",
    "url": "{{ site.url }}/contact.html",
    "mainEntity": {
        "@type": "Person",
        "name": "{{ site.author }}",
        "jobTitle": "{{ site.jobTitle }}",
        "email": "{{ site.email }}",
        "url": "{{ site.url }}",
        "sameAs": [
            "{{ site.social.github }}",
            "{{ site.social.gitlab }}",
            "{{ site.social.blog }}"
        ]
    }
}
</script>
{% endblock %}

<h1 id="contact">Contact</h1>
<p class="lead">Feel free to reach out to me via email or connect with me on social media.</p>

<div class="grid md:grid-cols-2 gap-6 mt-8">
    <div class="card">
        <h3><i class="fa-solid fa-envelope fa-fw"></i> Email</h3>
        <p>For professional inquiries and collaboration.</p>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
    </div>

    <div class="card">
        <h3><i class="fa-brands fa-github fa-fw"></i> GitHub</h3>
        <p>Explore my open-source work and contributions.</p>
        <a href="{{ site.social.github }}" target="_blank" rel="noopener">@SyafiqHadzir &rarr;</a>
    </div>

    <div class="card">
        <h3><i class="fa-solid fa-signature fa-fw"></i> Blog</h3>
        <p>Insights on software testing and test automation.</p>
        <a href="{{ site.social.blog }}" target="_blank" rel="noopener">blog.syafiqhadzir.dev &rarr;</a>
    </div>

    <div class="card">
        <h3><i class="fa-brands fa-gitlab fa-fw"></i> GitLab</h3>
        <p>Alternative repositories and legacy projects.</p>
        <a href="{{ site.social.gitlab }}" target="_blank" rel="noopener">GitLab Profile &rarr;</a>
    </div>
</div>

<hr class="section-divider">
